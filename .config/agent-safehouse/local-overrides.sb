;;; Local machine overrides — appended after safehouse's generated policy
;;; Loaded via SAFEHOUSE_APPEND_PROFILE

;;; ~/.config — broad read-only (jira-cli, gh, etc.)
(allow file-read*
  (home-subpath "/.config"))

;;; ~/.claude — full r/w for Claude Code state
(allow file-read* file-write*
  (home-literal "/.claude")
  (home-subpath "/.claude"))

;;; ~/dev — r/w across all project repos
(allow file-read* file-write*
  (home-literal "/dev")
  (home-subpath "/dev"))

;;; ~/jcloud — r/w for Syncthing-synced org files and agent scratch workspace
(allow file-read* file-write*
  (home-literal "/jcloud")
  (home-subpath "/jcloud"))

;;; ~/.opencode — r/w for OpenCode agent data
(allow file-read* file-write*
  (home-literal "/.opencode")
  (home-subpath "/.opencode"))

;;; ~/.pi — r/w for pi agent data
(allow file-read* file-write*
  (home-literal "/.pi")
  (home-subpath "/.pi"))

;;; ~/.agents — shared agent skills (symlinked from ~/.claude/skills)
(allow file-read* file-write*
  (home-literal "/.agents")
  (home-subpath "/.agents"))

;;; ~/.local/share/yadm — yadm dotfile manager repo
(allow file-read* file-write*
  (home-subpath "/.local/share/yadm"))

;;; ~/.local/share/recall — recall transcript search database
(allow file-read* file-write*
  (home-literal "/.local/share/recall")
  (home-subpath "/.local/share/recall"))

;;; ~/.config/gws — r/w for gws token cache and keyring backup
(allow file-read* file-write*
  (home-literal "/.config/gws")
  (home-subpath "/.config/gws"))

;;; ~/.config/doom — r/w for Doom Emacs
(allow file-read* file-write*
  (home-subpath "/.config/doom"))

;;; ~/.config/nobl9 — r/w for sloctl (Nobl9 CLI)
;;; Access-token post-hook rewrites config.toml via a temp file in the same
;;; dir on every invocation, so directory write access is required.
(allow file-read* file-write*
  (home-literal "/.config/nobl9")
  (home-subpath "/.config/nobl9"))

;;; superset-query — session state and CSRF token
(allow file-read* file-write*
  (home-literal "/.superset-cookies")
  (home-literal "/.superset-csrf-token"))

;;; ~/.local/bin — r/w+execute for custom symlinked tools
(allow file-read* file-write* process-exec
  (home-subpath "/.local/bin"))

;;; ztoken — config and token cache in ~/Library/Application Support
(allow file-read* file-write*
  (home-literal "/Library/Application Support")
  (home-literal "/Library/Application Support/zalando-token-cli")
  (home-subpath "/Library/Application Support/zalando-token-cli"))

;;; zkubectl — config, kubelogin binary, and cached tokens
(allow file-read* file-write*
  (home-literal "/Library/Application Support/zalando-kubectl")
  (home-subpath "/Library/Application Support/zalando-kubectl"))

;;; Kotlin compiler daemon — marker files for daemon-client liveness checks
(allow file-read* file-write*
  (home-literal "/Library/Application Support/kotlin")
  (home-literal "/Library/Application Support/kotlin/daemon")
  (home-subpath "/Library/Application Support/kotlin/daemon"))

;;; zalando-aws-cli — Okta token cache and AWS credentials
;;; greyhound.sh → zalando-aws-cli login → mkdir ~/.okta_cache, write tokens
;;; greyhound.sh → aws s3 cp → read ~/.aws/credentials
(allow file-read* file-write*
  (home-literal "/.okta_cache")
  (home-subpath "/.okta_cache")
  (home-literal "/.aws")
  (home-subpath "/.aws"))

;;; ~/.kube — r/w for zkubectl / kubectl cluster access
(allow file-read* file-write*
  (home-literal "/.kube")
  (home-subpath "/.kube"))

;;; ~/.dash0 — r/w for dash0 CLI profiles and OAuth token cache
(allow file-read* file-write*
  (home-literal "/.dash0")
  (home-subpath "/.dash0"))

;;; ~/.workspace-mcp — r/w for workspace-cli (google-workspace-mcp) OAuth token cache
;;; Stores Fernet encryption key (.cli-encryption-key) and encrypted tokens (cli-tokens/)
;;; so a sandboxed agent can reuse the consent granted during interactive login.
(allow file-read* file-write*
  (home-literal "/.workspace-mcp")
  (home-subpath "/.workspace-mcp"))

;;; ~/.gitconfig — read-only for git configuration
;;; ~/.testcontainers.properties — OrbStack docker socket path for Testcontainers
;;; ~/.kagi.toml — Kagi CLI session credentials
;;; ~/.zmon-cli.yaml — ZMON CLI configuration (URL + auth)
(allow file-read*
  (home-literal "/.gitconfig")
  (home-literal "/.testcontainers.properties")
  (home-literal "/.kagi.toml")
  (home-literal "/.zmon-cli.yaml"))

;;; OrbStack — read+execute for docker/kubectl binaries
(allow file-read* process-exec
  (home-subpath "/.orbstack")
  (subpath "/Applications/OrbStack.app/Contents/MacOS/xbin"))

;;; ~/icloud → iCloud Drive symlink; sandbox resolves through it
;;; Need both the symlink itself and the resolved target path
(allow file-read* file-write*
  (home-literal "/icloud")
  (home-subpath "/icloud")
  (home-literal "/Library/Mobile Documents")
  (home-literal "/Library/Mobile Documents/com~apple~CloudDocs")
  (home-literal "/Library/Mobile Documents/com~apple~CloudDocs/_notes")
  (home-subpath "/Library/Mobile Documents/com~apple~CloudDocs/_notes")
  (home-literal "/Library/Mobile Documents/com~apple~CloudDocs/org")
  (home-subpath "/Library/Mobile Documents/com~apple~CloudDocs/org"))

;;; Google Drive org; sandbox resolves through CloudStorage target path
(allow file-read* file-write*
  (home-literal "/Library/CloudStorage")
  (home-literal "/Library/CloudStorage/GoogleDrive-florian.dietrich.external@zalando.de")
  (home-literal "/Library/CloudStorage/GoogleDrive-florian.dietrich.external@zalando.de/My Drive")
  (home-literal "/Library/CloudStorage/GoogleDrive-florian.dietrich.external@zalando.de/My Drive/org")
  (home-subpath "/Library/CloudStorage/GoogleDrive-florian.dietrich.external@zalando.de/My Drive/org"))

;;; CleanShot — read-only access to screenshot media
(allow file-read*
  (home-literal "/Library/Application Support/CleanShot")
  (home-literal "/Library/Application Support/CleanShot/media")
  (home-subpath "/Library/Application Support/CleanShot/media"))

;;; SSH public keys — needed by IdentityFile directives for 1Password agent matching
(allow file-read*
  (home-literal "/.ssh/id_zalando.pub")
  (home-literal "/.ssh/id_personal.pub"))

;;; Keychain — go-keyring and similar tools in pi/opencode sessions
;;; (claude-code.sb already injects this; pi.sb and opencode.sb do not)
(allow mach-lookup
  (global-name "com.apple.SecurityServer")
  (global-name "com.apple.security.agent")
  (global-name "com.apple.securityd.xpc")
  (global-name "com.apple.security.authhost")
  (global-name "com.apple.secd")
  (global-name "com.apple.trustd"))
(allow file-read* file-write*
  (home-subpath "/Library/Keychains")
  (home-literal "/Library/Preferences/com.apple.security.plist"))
(allow file-read*
  (literal "/Library/Keychains/System.keychain")
  (subpath "/private/var/db/mds"))
(allow file-read-metadata
  (home-literal "/Library/Keychains")
  (literal "/Library/Keychains"))
(allow ipc-posix-shm-read-data ipc-posix-shm-write-create ipc-posix-shm-write-data
  (ipc-posix-name "com.apple.AppleDatabaseChanged"))

;;; ~/.aliases — shell alias file
(allow file-read* file-write*
  (home-literal "/.aliases"))

;;; ~/notes — research notes and pi research config
(allow file-read* file-write*
  (home-literal "/notes")
  (home-subpath "/notes"))

;;; Rodney / go-rod — browser automation via Chrome DevTools Protocol
;;; go-rod downloads Chromium into ~/.cache/rod; rodney stores session in ~/.rodney
;;; Use safehouse --enable=chromium-headless for full Chromium sandbox support
;;; (Crashpad, Mach ports, GPU, etc.) — these rules only cover file paths.
(allow file-read* file-write*
  (home-literal "/.cache")
  (home-literal "/.cache/rod")
  (home-subpath "/.cache/rod")
  (home-literal "/.cache/kagi-cli")
  (home-subpath "/.cache/kagi-cli")
  (home-literal "/.cache/huggingface")
  (home-subpath "/.cache/huggingface")
  (home-literal "/.rodney")
  (home-subpath "/.rodney"))

;;; agent-browser — native browser automation; downloads Chrome for Testing into
;;; ~/.agent-browser and stores managed profiles/session state alongside it.
;;; Chrome for Testing also writes Crashpad state under ~/Library/Application Support.
(allow file-read* file-write* process-exec
  (home-literal "/.agent-browser")
  (home-subpath "/.agent-browser"))
(allow file-read* file-write*
  (home-literal "/Library/Application Support/Google")
  (home-subpath "/Library/Application Support/Google")
  (home-literal "/Library/Application Support/Chromium")
  (home-subpath "/Library/Application Support/Chromium"))

;;; JVM self-attach socket (Mockito inline mock maker / ByteBuddy agent).
;;; safehouse 0.11.0 replaced the blanket (allow network*) with TCP/UDP/DNS-only
;;; grants, denying UNIX sockets by default. The JDK attach API rendezvous is a
;;; UNIX socket at $TMPDIR/.java_pid<pid> (kernel-resolved under /private/var/folders),
;;; so Mockito's self-attach fails with "Could not self-attach" and every mocking
;;; test errors with "Could not initialize plugin: MockMaker". Scope the grant to
;;; the JVM attach socket name only; regex tolerates the per-boot /var/folders nonce.
(allow network-bind network-inbound
  (local  unix-socket (regex #"^/private/var/folders/[^/]+/[^/]+/T/\.java_pid[0-9]+")))
(allow network-outbound
  (remote unix-socket (regex #"^/private/var/folders/[^/]+/[^/]+/T/\.java_pid[0-9]+")))

;;; Embedded PostgreSQL (Zonky / test suites) — initdb + postmaster need SysV shm/sem
;;; and POSIX shm segments under the /PostgreSQL.<nonce> name family. Without these,
;;; Spring Boot component tests fail with "Failed to load ApplicationContext" because
;;; embedded-postgres cannot start; one failure cascades across the whole suite.
(allow ipc-sysv-shm)
(allow ipc-sysv-sem)
(allow ipc-posix-shm-read-data ipc-posix-shm-read-metadata
       ipc-posix-shm-write-create ipc-posix-shm-write-data ipc-posix-shm-write-unlink
  (ipc-posix-name-regex #"^/PostgreSQL\."))
;;; Zonky's postmaster listens on a UNIX socket at /tmp/.s.PGSQL.<port> (kernel-
;;; resolved under /private/tmp) and the JDBC driver connects to it. safehouse
;;; 0.11.0's default-deny on UNIX sockets makes postmaster startup fail with
;;; "Gave up waiting for server to start" / "Connection refused". Scope the grant
;;; to the PostgreSQL socket name only.
(allow network-bind network-inbound
  (local  unix-socket (regex #"^/private/tmp/\.s\.PGSQL\.[0-9]+")))
(allow network-outbound
  (remote unix-socket (regex #"^/private/tmp/\.s\.PGSQL\.[0-9]+")))

;;; 1Password SSH agent socket — connect() re-allow for git commit signing.
;;; safehouse 0.11.0's bundled 55-integrations-optional/1password.sb grants
;;; file-read*/file-write* on the agent socket but — unlike docker.sb — omits the
;;; matching network-outbound (connect) re-allow that 0.11.0's default-deny on UNIX
;;; sockets now requires (see 20-network.sb: blanket (allow network*) was replaced
;;; with TCP/UDP/DNS-only grants). Result: op-ssh-sign fails with "1Password: Could
;;; not connect to socket. Is the agent running?" and every signed `git commit`
;;; aborts with "failed to write commit object", despite --enable=1password being set.
;;; Upstream bug — still unfixed on main as of 2026-07-10 (profile unchanged); the
;;; 0.11.0 op-ssh-sign support (PR #108) only added app-bundle *read* access, not the
;;; socket connect grant. Verified: this rule makes signed commits succeed inside the
;;; sandbox. Scope to the 1Password agent socket only; team prefix varies per install,
;;; so mirror the profile's own regex. Remove once upstream ships the connect re-allow.
(allow network-outbound
  (remote unix-socket (regex (string-append "^" HOME_DIR "/Library/Group Containers/[A-Za-z0-9]+\\.com\\.1password/t/agent\\.sock$"))))
