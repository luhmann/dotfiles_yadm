;;; Local machine overrides — appended after safehouse's generated policy
;;; Loaded via SAFEHOUSE_APPEND_PROFILE

;;; ~/.config — broad read-only (jira-cli, gh, etc.)
(allow file-read*
  (home-subpath "/.config"))

;;; ~/.claude — full r/w for Claude Code state
(allow file-read* file-write*
  (home-literal "/.claude")
  (home-subpath "/.claude"))

;;; ~/dev — r/w across all project repos
(allow file-read* file-write*
  (home-literal "/dev")
  (home-subpath "/dev"))

;;; ~/.opencode — r/w for OpenCode agent data
(allow file-read* file-write*
  (home-literal "/.opencode")
  (home-subpath "/.opencode"))

;;; ~/.pi — r/w for pi agent data
(allow file-read* file-write*
  (home-literal "/.pi")
  (home-subpath "/.pi"))

;;; ~/.agents — shared agent skills (symlinked from ~/.claude/skills)
(allow file-read* file-write*
  (home-literal "/.agents")
  (home-subpath "/.agents"))

;;; ~/.local/share/yadm — yadm dotfile manager repo
(allow file-read* file-write*
  (home-subpath "/.local/share/yadm"))

;;; ~/.config/gws — r/w for gws token cache and keyring backup
(allow file-read* file-write*
  (home-literal "/.config/gws")
  (home-subpath "/.config/gws"))

;;; ~/.config/doom — r/w for Doom Emacs
(allow file-read* file-write*
  (home-subpath "/.config/doom"))

;;; superset-query — session state and CSRF token
(allow file-read* file-write*
  (home-literal "/.superset-cookies")
  (home-literal "/.superset-csrf-token"))

;;; ~/.local/bin — r/w+execute for custom symlinked tools
(allow file-read* file-write* process-exec
  (home-subpath "/.local/bin"))

;;; ztoken — config and token cache in ~/Library/Application Support
(allow file-read* file-write*
  (home-literal "/Library/Application Support")
  (home-literal "/Library/Application Support/zalando-token-cli")
  (home-subpath "/Library/Application Support/zalando-token-cli"))

;;; Kotlin compiler daemon — marker files for daemon-client liveness checks
(allow file-read* file-write*
  (home-literal "/Library/Application Support/kotlin")
  (home-literal "/Library/Application Support/kotlin/daemon")
  (home-subpath "/Library/Application Support/kotlin/daemon"))

;;; zalando-aws-cli — Okta token cache and AWS credentials
;;; greyhound.sh → zalando-aws-cli login → mkdir ~/.okta_cache, write tokens
;;; greyhound.sh → aws s3 cp → read ~/.aws/credentials
(allow file-read* file-write*
  (home-literal "/.okta_cache")
  (home-subpath "/.okta_cache")
  (home-literal "/.aws")
  (home-subpath "/.aws"))

;;; ~/.gitconfig — read-only for git configuration
;;; ~/.testcontainers.properties — OrbStack docker socket path for Testcontainers
(allow file-read*
  (home-literal "/.gitconfig")
  (home-literal "/.testcontainers.properties"))

;;; OrbStack — read+execute for docker/kubectl binaries
(allow file-read* process-exec
  (home-subpath "/.orbstack")
  (subpath "/Applications/OrbStack.app/Contents/MacOS/xbin"))

;;; ~/icloud → iCloud Drive symlink; sandbox resolves through it
;;; Need both the symlink itself and the resolved target path
(allow file-read* file-write*
  (home-literal "/icloud")
  (home-subpath "/icloud")
  (home-literal "/Library/Mobile Documents")
  (home-literal "/Library/Mobile Documents/com~apple~CloudDocs")
  (home-literal "/Library/Mobile Documents/com~apple~CloudDocs/org")
  (home-subpath "/Library/Mobile Documents/com~apple~CloudDocs/org"))

;;; Google Drive org; sandbox resolves through CloudStorage target path
(allow file-read* file-write*
  (home-literal "/Library/CloudStorage")
  (home-literal "/Library/CloudStorage/GoogleDrive-florian.dietrich.external@zalando.de")
  (home-literal "/Library/CloudStorage/GoogleDrive-florian.dietrich.external@zalando.de/My Drive")
  (home-literal "/Library/CloudStorage/GoogleDrive-florian.dietrich.external@zalando.de/My Drive/org")
  (home-subpath "/Library/CloudStorage/GoogleDrive-florian.dietrich.external@zalando.de/My Drive/org"))

;;; CleanShot — read-only access to screenshot media
(allow file-read*
  (home-literal "/Library/Application Support/CleanShot")
  (home-literal "/Library/Application Support/CleanShot/media")
  (home-subpath "/Library/Application Support/CleanShot/media"))

;;; SSH public keys — needed by IdentityFile directives for 1Password agent matching
(allow file-read*
  (home-literal "/.ssh/id_zalando.pub")
  (home-literal "/.ssh/id_personal.pub"))

;;; Keychain — go-keyring and similar tools in pi/opencode sessions
;;; (claude-code.sb already injects this; pi.sb and opencode.sb do not)
(allow mach-lookup
  (global-name "com.apple.SecurityServer")
  (global-name "com.apple.security.agent")
  (global-name "com.apple.securityd.xpc")
  (global-name "com.apple.security.authhost")
  (global-name "com.apple.secd")
  (global-name "com.apple.trustd"))
(allow file-read* file-write*
  (home-subpath "/Library/Keychains")
  (home-literal "/Library/Preferences/com.apple.security.plist"))
(allow file-read*
  (literal "/Library/Keychains/System.keychain")
  (subpath "/private/var/db/mds"))
(allow file-read-metadata
  (home-literal "/Library/Keychains")
  (literal "/Library/Keychains"))
(allow ipc-posix-shm-read-data ipc-posix-shm-write-create ipc-posix-shm-write-data
  (ipc-posix-name "com.apple.AppleDatabaseChanged"))

;;; Rodney / go-rod — browser automation via Chrome DevTools Protocol
;;; go-rod downloads Chromium into ~/.cache/rod; rodney stores session in ~/.rodney
;;; Use safehouse --enable=chromium-headless for full Chromium sandbox support
;;; (Crashpad, Mach ports, GPU, etc.) — these rules only cover file paths.
(allow file-read* file-write*
  (home-literal "/.cache")
  (home-literal "/.cache/rod")
  (home-subpath "/.cache/rod")
  (home-literal "/.rodney")
  (home-subpath "/.rodney"))

;;; Embedded PostgreSQL (Zonky / test suites) — initdb + postmaster need SysV shm/sem
;;; and POSIX shm segments under the /PostgreSQL.<nonce> name family. Without these,
;;; Spring Boot component tests fail with "Failed to load ApplicationContext" because
;;; embedded-postgres cannot start; one failure cascades across the whole suite.
(allow ipc-sysv-shm)
(allow ipc-sysv-sem)
(allow ipc-posix-shm-read-data ipc-posix-shm-read-metadata
       ipc-posix-shm-write-create ipc-posix-shm-write-data ipc-posix-shm-write-unlink
  (ipc-posix-name-regex #"^/PostgreSQL\."))
